---
const experience = [
  {
    role: "Desarrollador de software",
    company: "Consejo de Aseguramiento de la Calidad de la Educación Superior - CACES",
    period: "feb. 2017 – actualidad (9 años 2 meses)",
    location: "Quito, Pichincha, Ecuador",
    desc: "Desarrollo y mantenimiento de aplicaciones internas para gestión de calidad educativa. Trabajo fullstack con tecnologías modernas."
  },
  {
    role: "Desarrollador de software",
    company: "Pagupa Soft",
    period: "dic. 2015 – ene. 2017 (1 año 2 meses)",
    location: "Machala, El Oro, Ecuador",
    desc: "Desarrollo de software a medida para clientes locales."
  }
];
---
<section id="experience" class="py-24 px-6 bg-gray-50 dark:bg-gray-900/50">
  <div class="max-w-4xl mx-auto">
    <h2 class="text-3xl md:text-4xl font-bold mb-3 text-center">Experiencia Laboral</h2>
    <div class="w-16 h-1 bg-blue-600 mx-auto rounded-full mb-12"></div>
    <div class="space-y-10">
      {experience.map((exp) => (
        <div class="relative pl-10 border-l-2 border-blue-200 dark:border-blue-900 group">
          <div class="absolute -left-2.5 top-1.5 w-5 h-5 bg-blue-600 rounded-full ring-4 ring-white dark:ring-gray-950 group-hover:scale-110 transition-transform"></div>
          <div class="bg-white dark:bg-gray-900 rounded-xl p-6 shadow-sm border border-gray-100 dark:border-gray-800 hover:shadow-md hover:-translate-y-0.5 transition-all">
            <h3 class="text-xl font-bold text-gray-900 dark:text-gray-100">{exp.role}</h3>
            <p class="text-blue-600 dark:text-blue-400 font-semibold mt-1">{exp.company}</p>
            <p class="text-sm text-gray-500 dark:text-gray-400 mt-1">{exp.period} · {exp.location}</p>
            <p class="mt-3 text-gray-700 dark:text-gray-300 leading-relaxed">{exp.desc}</p>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
