---
const BASE = import.meta.env.BASE_URL;
// Returns correct URL for both local and external images
const imgSrc = (preview: string) =>
  preview.startsWith('http') ? preview : `${BASE}${preview}`;

const projects = [
  {
    title: "Resto Admin App",
    desc: "Dashboard administrativo para restaurantes (fullstack con autenticación y base de datos).",
    tech: ["TypeScript", "Next.js", "Prisma", "Tailwind"],
    repo: "https://github.com/jold1992/resto-admin-app",
    live: "https://resto-admin-app.vercel.app",
    preview: "resto-admin-app.png",
  },
  {
    title: "Weather App",
    desc: "App para visualizar el clima de una ciudad específica.",
    tech: ["Javascript", "Astro"],
    repo: "https://github.com/jold1992/weather-app",
    live: "https://jold1992.github.io/weather-app/",
    preview: "weather-app.png",
  },
  {
    title: "Crypto Price App",
    desc: "App para visualizar el precio de criptomonedas.",
    tech: ["TypeScript", "Astro"],
    repo: "https://github.com/jold1992/crypto-price-app",
    live: "https://crypto-price-app-lilac.vercel.app/",
    preview: "crypto-price-app.png",
  },
  {
    title: "Buscaminas Game",
    desc: "Juego clásico de buscaminas con diseño responsive.",
    tech: ["Javascript", "Html", "Css"],
    repo: "https://github.com/jold1992/buscaminas-game",
    live: "https://jold1992.github.io/buscaminas-game/",
    preview: "Buscaminas-Game.png",
  },
  {
    title: "Space Calendar",
    desc: "App para visualizar el calendario espacial.",
    tech: ["TypeScript", "Astro"],
    repo: "https://github.com/jold1992/space-calendar",
    live: "https://jold1992.github.io/space-calendar/",
    preview: "Space-Calendar.png",
  },
  {
    title: "Netflix Clone",
    desc: "Clon de Netflix con consumo de API y diseño responsive.",
    tech: ["TypeScript", "Next.js"],
    repo: "https://github.com/jold1992/netflix-clone-nextjs",
    live: "",
    preview: "netflix-clone-app.png",
  },
  {
    title: "Custom Hooks Library",
    desc: "Colección de hooks reutilizables para mejorar productividad en React.",
    tech: ["JavaScript", "React"],
    repo: "https://github.com/jold1992/mis-custom-hook",
    live: "",
    preview: "https://opengraph.githubassets.com/1/jold1992/mis-custom-hook",
  },
  {
    title: "Next.js Auth + Prisma",
    desc: "Sistema de autenticación completo con NextAuth, Prisma y PostgreSQL.",
    tech: ["TypeScript", "Next.js", "Prisma", "PostgreSQL"],
    repo: "https://github.com/jold1992/nextjs-auth-prisma",
    live: "",
    preview: "https://opengraph.githubassets.com/1/jold1992/nextjs-auth-prisma",
  },
  {
    title: "Gift for Mom's day",
    desc: "App para generar un mensaje por el día de las madres.",
    tech: ["Javascript"],
    repo: "https://github.com/jold1992/gift-app-moms-day",
    live: "https://jold1992.github.io/gift-app-moms-day/",
    preview: "present-mom-day-app.png",
  },
];
---
<section id="projects" class="py-24 px-6">
  <div class="max-w-6xl mx-auto">
    <h2 class="text-3xl md:text-4xl font-bold mb-3 text-center">Proyectos Destacados</h2>
    <div class="w-16 h-1 bg-blue-600 mx-auto rounded-full mb-12"></div>
    <div class="grid grid-cols-1 sm:grid-cols-2 gap-6">
      {projects.map(project => (
        <div class="group relative bg-white dark:bg-gray-900 rounded-2xl overflow-hidden shadow-sm border border-gray-100 dark:border-gray-800 hover:shadow-xl hover:-translate-y-2 hover:border-blue-300 dark:hover:border-blue-700 transition-all duration-300 flex flex-col">
          <!-- Preview image (clickable → live or repo) -->
          <a
            href={project.live || project.repo}
            target="_blank"
            rel="noopener noreferrer"
            class="relative overflow-hidden bg-gray-100 dark:bg-gray-800 aspect-2/1 block"
            aria-label={project.live ? `Ver ${project.title} en vivo` : `Ver ${project.title} en GitHub`}
          >
            <img
              src={imgSrc(project.preview)}
              alt={`Preview de ${project.title}`}
              class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-105"
              loading="lazy"
            />
            <!-- Overlay on hover -->
            <div class="absolute inset-0 bg-blue-600/0 group-hover:bg-blue-600/15 transition-colors duration-300 flex items-center justify-center">
              <span class="opacity-0 group-hover:opacity-100 transition-opacity duration-300 bg-white/90 dark:bg-gray-900/90 text-blue-600 dark:text-blue-400 font-semibold text-sm px-4 py-2 rounded-lg shadow flex items-center gap-2">
                <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"/>
                </svg>
                {project.live ? "Ver en vivo" : "Ver en GitHub"}
              </span>
            </div>
          </a>

          <!-- Top accent bar -->
          <div class="h-1 w-full bg-linear-to-r from-blue-500 to-indigo-500 transform scale-x-0 group-hover:scale-x-100 transition-transform duration-300 origin-left"></div>

          <!-- Content -->
          <div class="p-6 flex flex-col flex-1">
            <h3 class="text-xl font-bold text-gray-900 dark:text-gray-100 mb-2 group-hover:text-blue-600 dark:group-hover:text-blue-400 transition-colors">
              {project.title}
            </h3>
            <p class="text-gray-600 dark:text-gray-400 mb-4 text-sm leading-relaxed flex-1">{project.desc}</p>
            <div class="flex flex-wrap gap-2 mb-5">
              {project.tech.map(t => (
                <span class="px-2.5 py-1 rounded-md bg-gray-100 dark:bg-gray-800 text-gray-600 dark:text-gray-400 text-xs font-medium">{t}</span>
              ))}
            </div>
            <!-- Action buttons -->
            <div class="flex gap-3 mt-auto pt-4 border-t border-gray-100 dark:border-gray-800">
              {project.live && (
                <a href={project.live} target="_blank" rel="noopener noreferrer"
                  class="flex-1 text-center px-3 py-2 rounded-lg bg-blue-600 hover:bg-blue-700 text-white text-xs font-semibold transition-colors flex items-center justify-center gap-1.5">
                  <svg xmlns="http://www.w3.org/2000/svg" class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/>
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z"/>
                  </svg>
                  Ver en vivo
                </a>
              )}
              <a href={project.repo} target="_blank" rel="noopener noreferrer"
                class="flex-1 text-center px-3 py-2 rounded-lg border border-gray-200 dark:border-gray-700 hover:border-blue-400 dark:hover:border-blue-500 text-gray-600 dark:text-gray-400 hover:text-blue-600 dark:hover:text-blue-400 text-xs font-semibold transition-colors flex items-center justify-center gap-1.5">
                <svg xmlns="http://www.w3.org/2000/svg" class="w-3.5 h-3.5" fill="currentColor" viewBox="0 0 24 24">
                  <path d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.337 1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.019 10.019 0 0022 12.017C22 6.484 17.522 2 12 2z"/>
                </svg>
                GitHub
              </a>
            </div>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
